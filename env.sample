# MUST BE RADDRESS
PRIMARY_ADDRESS=
# R-ADDRESS, I-ADDRESS or FRIENDLY NAME@
SOURCE_OF_FUNDS=""
# FRIENDLY NAME
DELIVER_ID_CONTROL_TOKEN="blockoneminer@"
# Z-ADDRESS, R-ADDRESS, I-ADDRESS or FRIENDLY NAME
SOURCE_OF_FUNDS=""
# Z-ADDRESS
Z_ADDRESS=""
# TICKER OF NATIVE COIN, e.g VRSCTEST, VRSC, VARRR, VDEX, CHIPS
NATIVE_COIN="VRSCTEST"
# I-ADDRESS or FRIENDLY NAME
REFERRAL_ID=""
# INTEGER
MINIMUM_SIGNATURES=1
# PARENT CURRENCY, e.g. "bitcoins.vrsc"
PARENT=
# Optional explicit single allowed parent for /api/register (same behavior as PARENT)
REGISTRAR_ALLOWED_PARENT=
# Optional comma-separated allowed parents for /api/register, e.g. "bitcoins.vrsc,private.vrsc"
REGISTRAR_ALLOWED_PARENTS=
# fee offer, the id registration fee
FEE_OFFER=
REGISTRAR_API_KEYS=
# Optional explicit single allowed parent for /api/register (same behavior as PARENT)
REGISTRAR_ALLOWED_PARENT=
# Optional comma-separated allowed parents for /api/register, e.g. "bitcoins.vrsc,private.vrsc"
REGISTRAR_ALLOWED_PARENTS=


# Daemon name to use for /health RPC check
HEALTH_RPC_DAEMON="verusd_vrsc"

# Provisioning adapter mode: must be http
PROVISIONING_ADAPTER_MODE="http"
# URL for provisioning HTTP service
PROVISIONING_SERVICE_URL="http://127.0.0.1:5055"
# HTTP timeout (seconds) for provisioning adapter requests
PROVISIONING_HTTP_TIMEOUT_SECONDS="10"
# Retry count for transient provisioning HTTP failures
PROVISIONING_RETRY_COUNT="1"
# Log level for provisioning-related Python logs
PROVISIONING_LOG_LEVEL="INFO"

# vrsctest rpc
verusd_vrsctest_rpc_enabled     = "false"
verusd_vrsctest_rpc_user        = ""
verusd_vrsctest_rpc_password    = ""
verusd_vrsctest_rpc_port        = ""
verusd_vrsctest_rpc_host        = ""

# vrsc rpc
verusd_vrsc_rpc_enabled     = "false"
verusd_vrsc_rpc_user        = ""
verusd_vrsc_rpc_password    = ""
verusd_vrsc_rpc_port        = ""
verusd_vrsc_rpc_host        = ""

# varrr rpc
verusd_varrr_rpc_enabled    = "false"
verusd_varrr_rpc_user       = ""
verusd_varrr_rpc_password   = ""
verusd_varrr_rpc_port       = ""
verusd_varrr_rpc_host       = ""

# vdex rpc
verusd_vdex_rpc_enabled     = "false"
verusd_vdex_rpc_user        = ""
verusd_vdex_rpc_password    = ""
verusd_vdex_rpc_port        = ""
verusd_vdex_rpc_host        = ""

# chips rpc
verusd_chips_rpc_enabled    = "false"
verusd_chips_rpc_user       = ""
verusd_chips_rpc_password   = ""
verusd_chips_rpc_port       = ""
verusd_chips_rpc_host       = ""
